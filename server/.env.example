PORT=5000
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=EdgeIQ

# Firebase Admin — download from Firebase Console → Project Settings → Service Accounts
FIREBASE_SERVICE_ACCOUNT_PATH=./config/serviceAccountKey.json

# API-Football (api-sports.io direct)
APIFOOTBALL_KEY=your_api_football_key_here
APIFOOTBALL_HOST=v3.football.api-sports.io

# Football98 via RapidAPI
FOOTBALL98_KEY=your_rapidapi_key_here
FOOTBALL98_HOST=football98.p.rapidapi.com

# VAPID keys — generate once with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here
VAPID_EMAIL=mailto:admin@yourdomain.com
